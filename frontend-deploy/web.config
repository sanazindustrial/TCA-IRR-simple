<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <!-- Let iisnode handle all requests through server.js -->
      <add name="iisnode" path="server.js" verb="*" modules="iisnode"/>
    </handlers>
    <rewrite>
      <rules>
        <!-- Route all requests to Next.js server -->
        <rule name="NextJS" stopProcessing="true">
          <match url=".*" />
          <action type="Rewrite" url="server.js"/>
        </rule>
      </rules>
    </rewrite>
    <!-- Pass all HTTP errors to Next.js for handling -->
    <httpErrors existingResponse="PassThrough"/>
    <!-- iisnode configuration for Node.js -->
    <iisnode 
      nodeProcessCommandLine="node"
      watchedFiles="web.config;*.js"
      loggingEnabled="true"
      logDirectory="iisnode"/>
  </system.webServer>
</configuration>
